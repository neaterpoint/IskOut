<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeColor="#E2E8F0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivSpotImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_circle_light_blue"
            android:padding="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvRank"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="-8dp"
            android:layout_marginTop="-8dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="4dp"
            android:gravity="center"
            android:textColor="#0F172A"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/ivSpotImage"
            app:layout_constraintTop_toTopOf="@id/ivSpotImage" />

        <TextView
            android:id="@+id/tvSpotName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="#0F172A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/ivSpotImage"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivVerified"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_check_circle"
            app:tint="#3B82F6"
            app:layout_constraintBottom_toBottomOf="@id/tvSpotName"
            app:layout_constraintStart_toEndOf="@id/tvSpotName"
            app:layout_constraintTop_toTopOf="@id/tvSpotName" />

        <TextView
            android:id="@+id/tvSpotCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#64748B"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/tvSpotName"
            app:layout_constraintTop_toBottomOf="@id/tvSpotName" />

        <LinearLayout
            android:id="@+id/llStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="@id/tvSpotName"
            app:layout_constraintTop_toBottomOf="@id/tvSpotCategory">

            <TextView
                android:id="@+id/tvSpotRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_star"
                android:drawablePadding="4dp"
                android:drawableTint="#22708E"
                android:textColor="#0F172A"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpotPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="#22708E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSpotStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:drawableStart="@drawable/ic_dot_grey"
                android:drawablePadding="6dp"
                android:textColor="#64748B"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDealTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_badge_light_blue"
            android:drawableStart="@drawable/ic_tag"
            android:drawablePadding="6dp"
            android:drawableTint="#3B82F6"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#3B82F6"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvSpotName"
            app:layout_constraintTop_toBottomOf="@id/llStats" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>